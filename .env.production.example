# DS1 Hunter — Production Environment Variables
# Copy this to .env (inside web/) and fill in all values before deploying.
# Never commit .env to version control.

# ── Django core ────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_generate_a_long_random_string

DEBUG=False

# Comma-separated list of hostnames/IPs Django will serve
ALLOWED_HOSTS=ds1hunter.local,127.0.0.1,::1

# ── Django admin ───────────────────────────────────────────────────────────
# Use an obscure path — attackers should not be able to find it by guessing.
# Must end with a slash.  Example: h4nt-c0ntr0l-a8f2/
ADMIN_URL=CHANGE_ME_secret_admin_path/

# Comma-separated IPs allowed to reach the admin panel.
# Nginx does NOT proxy admin by default — this is a defence-in-depth layer.
ADMIN_ALLOWED_IPS=127.0.0.1,::1

# ── HTTPS ──────────────────────────────────────────────────────────────────
SECURE_SSL_REDIRECT=True

# ── CORS ───────────────────────────────────────────────────────────────────
# API on port 18000, frontend on port 13000 — adjust if using a reverse proxy.
# Include both if frontend makes direct API calls; no trailing slash.
CORS_ALLOWED_ORIGINS=https://127.0.0.1:13000,https://localhost:13000

# ── Database (PostgreSQL for production) ───────────────────────────────────
DB_NAME=ds1hunter
DB_USER=ds1hunter
DB_PASSWORD=CHANGE_ME_strong_db_password
DB_HOST=localhost
DB_PORT=5432

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_AVAILABLE=True
REDIS_URL=redis://localhost:6379/0

# ── OOB callback server — HTTP ─────────────────────────────────────────────
OOB_ENABLED=True
OOB_LISTEN_HOST=0.0.0.0
OOB_HTTP_PORT=8089
# Your public IP or domain — targets call back here
OOB_PUBLIC_HOST=CHANGE_ME_your_public_ip_or_domain

# ── OOB callback server — DNS ──────────────────────────────────────────────
OOB_DNS_ENABLED=True
OOB_DNS_PORT=53
OOB_DNS_FALLBACK_PORT=5353
# Delegate this domain to your server via NS record at your DNS registrar
# e.g.:  ns1.yourdomain.com → your_server_ip, then oast.yourdomain.com NS ns1.yourdomain.com
OOB_DNS_BASE_DOMAIN=oast.CHANGE_ME_your_domain

# ── Intercept proxy ────────────────────────────────────────────────────────
PROXY_ENABLED=True
PROXY_LISTEN_HOST=127.0.0.1
PROXY_PORT=8082

# ── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=WARNING
