# DS1 Hunter - Environment Variables
# DigitalSecurity1 - "Hunt. Chain. Prove."
#
# Copy this file to .env and fill in your values:
#   cp .env.example web/.env

# ─── Django ────────────────────────────────────────────────────────────────
SECRET_KEY=your-very-secret-key-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
LOG_LEVEL=INFO

# ─── Database (PostgreSQL) ─────────────────────────────────────────────────
DB_NAME=ds1hunter
DB_USER=ds1hunter
DB_PASSWORD=ds1hunter_pass
DB_HOST=localhost
DB_PORT=5432

# ─── Redis (optional for dev) ──────────────────────────────────────────────
# Set to True only if Redis is running
REDIS_AVAILABLE=False
REDIS_URL=redis://localhost:6379/0

# ─── Django Admin ───────────────────────────────────────────────────────────
# NEVER use "admin/" — pick a non-obvious path. Must end with a slash.
# The installer auto-generates this value; you can also set it manually.
ADMIN_URL=ds1-system-ops-x7k2/
# IPs allowed to reach Django admin (comma-separated, no spaces)
ADMIN_ALLOWED_IPS=127.0.0.1,::1

# ─── Ports ──────────────────────────────────────────────────────────────────
# API server listens on 18000   → start with: daphne -p 18000 ds1hunter_project.asgi:application
# Frontend dev server on 13000  → start with: PORT=13000 npm start (inside frontend/)

# ─── CORS ──────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:13000,http://127.0.0.1:13000

# ─── OOB / OAST — HTTP callback server ─────────────────────────────────────
# Detects blind vulnerabilities (SSRF, XXE, CMDi, Log4Shell) via outbound callbacks.
OOB_ENABLED=True
OOB_LISTEN_HOST=0.0.0.0
OOB_HTTP_PORT=8089
# Set to your machine's LAN or public IP so external targets can reach it.
# Leave blank to auto-detect LAN IP (works for targets on the same network).
OOB_PUBLIC_HOST=

# ─── OOB / OAST — DNS callback server ──────────────────────────────────────
# DNS callbacks work even when egress HTTP is firewalled.
# Payloads: nslookup, MSSQL xp_dirtree, MySQL LOAD_FILE UNC, Log4Shell JNDI DNS, etc.
OOB_DNS_ENABLED=True
# Port 53 requires root or: sudo setcap cap_net_bind_service+ep $(which python3)
# If port 53 is unavailable the server automatically falls back to OOB_DNS_FALLBACK_PORT.
OOB_DNS_PORT=53
OOB_DNS_FALLBACK_PORT=5353
# Subdomain base for DNS payloads — token is injected as: <token>.OOB_DNS_BASE_DOMAIN
# For external targets: delegate this domain to your machine via an NS record at your DNS registrar.
OOB_DNS_BASE_DOMAIN=oast.ds1h
